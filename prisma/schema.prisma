datasource db {
  provider = "sqlite"
  url      = "file:./data.db"
}

generator client {
  provider = "prisma-client-js"
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  tagName   String
  logo      String   // URL hoặc path ảnh
  color     String   // ví dụ: "#FF0000"

  players   Player[] // relation 1-n

  createdAt DateTime @default(now())
}

model Player {
  id      Int    @id @default(autoincrement())
  name    String
  role    String

  teamId  Int
  team    Team   @relation(fields: [teamId], references: [id])
}